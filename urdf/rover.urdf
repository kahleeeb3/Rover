<?xml version="1.0"?>
<robot name="rover">

  <material name="gray">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.06 0.06 0.06 1.0"/>
  </material>
  <material name="tread">
    <color rgba="0.22 0.22 0.22 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.35 0.28 0.05"/>
      </geometry>
      <origin xyz="0 0 -0.025"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.35 0.28 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.7"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <!-- Wheels: black inner cylinder (r=0.074) is the groove floor.
       8 wide tread blocks (outer edge r=0.080) cover most of the surface;
       the 8mm gaps between them expose the black cylinder = the grooves.
       Collision stays at r=0.080. -->
  <link name="front_left_wheel">
    <visual>
      <geometry><cylinder radius="0.074" length="0.07"/></geometry>
      <material name="black"/>
    </visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.077  0.000 0" rpy="0 0 0.000"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.054  0.054 0" rpy="0 0 0.785"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.000  0.077 0" rpy="0 0 1.571"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.054  0.054 0" rpy="0 0 2.356"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.077  0.000 0" rpy="0 0 3.142"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.054 -0.054 0" rpy="0 0 3.927"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.000 -0.077 0" rpy="0 0 4.712"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.054 -0.054 0" rpy="0 0 5.498"/><material name="tread"/></visual>
    <collision>
      <geometry><cylinder radius="0.08" length="0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="front_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.125 0.16 -0.025" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <geometry><cylinder radius="0.074" length="0.07"/></geometry>
      <material name="black"/>
    </visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.077  0.000 0" rpy="0 0 0.000"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.054  0.054 0" rpy="0 0 0.785"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.000  0.077 0" rpy="0 0 1.571"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.054  0.054 0" rpy="0 0 2.356"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.077  0.000 0" rpy="0 0 3.142"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.054 -0.054 0" rpy="0 0 3.927"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.000 -0.077 0" rpy="0 0 4.712"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.054 -0.054 0" rpy="0 0 5.498"/><material name="tread"/></visual>
    <collision>
      <geometry><cylinder radius="0.08" length="0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="front_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.125 -0.16 -0.025" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rear_left_wheel">
    <visual>
      <geometry><cylinder radius="0.074" length="0.07"/></geometry>
      <material name="black"/>
    </visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.077  0.000 0" rpy="0 0 0.000"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.054  0.054 0" rpy="0 0 0.785"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.000  0.077 0" rpy="0 0 1.571"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.054  0.054 0" rpy="0 0 2.356"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.077  0.000 0" rpy="0 0 3.142"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.054 -0.054 0" rpy="0 0 3.927"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.000 -0.077 0" rpy="0 0 4.712"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.054 -0.054 0" rpy="0 0 5.498"/><material name="tread"/></visual>
    <collision>
      <geometry><cylinder radius="0.08" length="0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="rear_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.125 0.16 -0.025" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rear_right_wheel">
    <visual>
      <geometry><cylinder radius="0.074" length="0.07"/></geometry>
      <material name="black"/>
    </visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.077  0.000 0" rpy="0 0 0.000"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.054  0.054 0" rpy="0 0 0.785"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.000  0.077 0" rpy="0 0 1.571"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.054  0.054 0" rpy="0 0 2.356"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.077  0.000 0" rpy="0 0 3.142"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz="-0.054 -0.054 0" rpy="0 0 3.927"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.000 -0.077 0" rpy="0 0 4.712"/><material name="tread"/></visual>
    <visual><geometry><box size="0.006 0.052 0.055"/></geometry><origin xyz=" 0.054 -0.054 0" rpy="0 0 5.498"/><material name="tread"/></visual>
    <collision>
      <geometry><cylinder radius="0.08" length="0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="rear_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.125 -0.16 -0.025" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>
